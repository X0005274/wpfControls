<?xml version="1.0" encoding="utf-8"?>
<!--
  com.example.Messaging.Rendezvous
  ─────────────────────────────────────────────────────────────────────────────
  A messaging library that does Request/Reply of server Methods over TIBCO
  Rendezvous (RV). Connection info is Service / Network / Daemon; the message
  address is a Subject.

  [IMPORTANT] This project builds only on a PC where the TIBCO Rendezvous .NET
  assembly (TIBCO.Rendezvous.dll) is installed. It requires this environment
  variable:
     TIBRV_HOME = the TIBCO RV install folder (e.g. C:\TIBCO\tibrv\8.6)
  The project then references $(TIBRV_HOME)\bin\TIBCO.Rendezvous.dll.
  On a PC without RV, unload this project so the rest of the solution still builds.
-->
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{D5F8B2C3-4E6A-4B7C-9D0E-1F2A3B4C5D6E}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>com.example.Messaging.Rendezvous</RootNamespace>
    <AssemblyName>com.example.Messaging.Rendezvous</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>7.3</LangVersion>
    <!-- Path to the TIBCO RV .NET assembly (based on the TIBRV_HOME env var). Override with a direct path if needed. -->
    <TibrvAssembly>$(TIBRV_HOME)\bin\TIBCO.Rendezvous.dll</TibrvAssembly>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <!-- TIBCO Rendezvous .NET API. CopyLocal=false: the RV runtime must be installed on the PC. -->
    <Reference Include="TIBCO.Rendezvous">
      <HintPath>$(TibrvAssembly)</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="obj\**\*.cs;bin\**\*.cs" />
  </ItemGroup>
  <!-- If the TIBCO assembly is missing, fail early with a clear message. -->
  <Target Name="CheckTibrv" BeforeTargets="ResolveAssemblyReferences">
    <Error Condition="!Exists('$(TibrvAssembly)')"
           Text="TIBCO.Rendezvous.dll was not found. Set the TIBRV_HOME environment variable to the TIBCO RV install folder, or edit the &lt;TibrvAssembly&gt; path in the csproj. Current path: $(TibrvAssembly)" />
  </Target>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
