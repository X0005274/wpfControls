<UserControl x:Class="com.example.Controls.Wpf.Feedback.ModernSpinnerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             x:Name="RootControl"
             d:DesignWidth="40" d:DesignHeight="40">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 회전하는 호(arc) 모양 스피너. 로딩 중임을 나타냅니다. -->
    <Grid Width="36" Height="36">
        <Ellipse Width="36" Height="36"
                 Stroke="{StaticResource Brush.BorderSubtle}"
                 StrokeThickness="4" />
        <Ellipse x:Name="ArcEllipse" Width="36" Height="36"
                 Stroke="{StaticResource Brush.Accent}"
                 StrokeThickness="4"
                 StrokeDashArray="22 100"
                 StrokeDashCap="Round"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="ArcRotate" Angle="0" />
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
