<UserControl x:Class="com.example.Controls.Wpf.Feedback.ModernLoadingPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:feedback="clr-namespace:com.example.Controls.Wpf.Feedback"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="320" d:DesignHeight="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 화면 전체를 살짝 어둡게 덮고, 가운데에 스피너와 안내 문구를 보여 줍니다. -->
    <Grid Background="{StaticResource Brush.Scrim}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <feedback:ModernSpinnerControl HorizontalAlignment="Center" />
            <TextBlock x:Name="MessageText"
                       Text="처리 중..."
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Body}"
                       FontWeight="Medium"
                       Foreground="White" />
        </StackPanel>
    </Grid>
</UserControl>
