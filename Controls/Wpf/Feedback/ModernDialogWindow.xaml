<Window x:Class="com.example.Controls.Wpf.Feedback.ModernDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource Font.Family}"
        Title="알림"
        Width="440"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 주요 버튼(확인) 스타일 -->
            <Style x:Key="DialogPrimaryButton" TargetType="Button">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="18,0" />
                <Setter Property="MinWidth" Value="76" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="{StaticResource Radius.Md}"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.92" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 보조 버튼(취소) 스타일 -->
            <Style x:Key="DialogSecondaryButton" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButton}">
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" CornerRadius="{StaticResource Radius.Md}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- 둥근 카드 + 그림자. 위쪽 색 막대(AccentBar)는 종류에 따라 색이 바뀝니다. -->
    <Border CornerRadius="{StaticResource Radius.Lg}"
            Background="{StaticResource Brush.Surface}"
            Effect="{StaticResource Shadow.Popup}"
            Margin="16">
        <StackPanel>
            <!-- 상단 색 막대(종류별 색) -->
            <Border x:Name="AccentBar" Height="5"
                    CornerRadius="8,8,0,0"
                    Background="{StaticResource Brush.Accent}" />

            <!-- 제목 영역(드래그로 창 이동 가능) -->
            <Border x:Name="TitleArea" Background="Transparent" MouseLeftButtonDown="TitleArea_MouseLeftButtonDown">
                <TextBlock x:Name="TitleText"
                           Text="알림"
                           Margin="24,20,24,0"
                           FontSize="{StaticResource Font.Size.Subtitle}" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}" />
            </Border>

            <!-- 본문 메시지 -->
            <TextBlock x:Name="MessageText"
                       Text=""
                       Margin="24,10,24,20"
                       FontSize="{StaticResource Font.Size.Body}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource Brush.TextSecondary}" />

            <!-- 버튼 영역 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,20">
                <Button x:Name="CancelButton" Content="취소"
                        Style="{StaticResource DialogSecondaryButton}"
                        Margin="0,0,8,0"
                        Click="CancelButton_Click" />
                <Button x:Name="OkButton" Content="확인"
                        Style="{StaticResource DialogPrimaryButton}"
                        Click="OkButton_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
