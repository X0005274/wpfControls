<UserControl x:Class="com.example.Controls.Wpf.Selection.ModernListBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="280" d:DesignHeight="220">
    <UserControl.Resources>

        <Style x:Key="ModernListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="4"
                                Margin="3,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF3F4F6" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFEFF6FF" />
                                <Setter Property="Foreground" Value="#FF1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title, ElementName=RootControl}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#FF1F2937"
                   Margin="0,0,0,6" />

        <Border Grid.Row="1"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="#FFD1D5DB"
                Background="#FFFFFFFF">
            <ListBox x:Name="InnerListBox"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource ModernListBoxItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                     SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                     DisplayMemberPath="{Binding DisplayMemberPath, ElementName=RootControl}"
                     IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
        </Border>
    </Grid>

</UserControl>
