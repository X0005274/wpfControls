<UserControl x:Class="com.example.Controls.Wpf.Selection.ModernCheckBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="320">
    <UserControl.Resources>

        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Box"
                                    Width="20" Height="20"
                                    CornerRadius="4"
                                    BorderThickness="1.5"
                                    BorderBrush="#FFD1D5DB"
                                    Background="#FFFFFFFF"
                                    VerticalAlignment="Top"
                                    Margin="0,1,0,0">
                                <Path x:Name="CheckMark"
                                      Width="12" Height="12"
                                      Stretch="Uniform"
                                      Stroke="#FFFFFFFF"
                                      StrokeThickness="2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Data="M2,6 L5,9 L10,3"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="10,0,0,0"
                                              VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FF2563EB" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF2563EB" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF2563EB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <CheckBox x:Name="InnerCheckBox"
              Style="{StaticResource ModernCheckBoxStyle}"
              Cursor="Hand"
              IsChecked="{Binding IsChecked, ElementName=RootControl, Mode=TwoWay}"
              IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}">
        <StackPanel>
            <TextBlock Text="{Binding Title, ElementName=RootControl}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FF1F2937" />
            <TextBlock Text="{Binding Description, ElementName=RootControl}"
                       FontSize="11"
                       Foreground="#FF6B7280"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
        </StackPanel>
    </CheckBox>

</UserControl>
