<UserControl x:Class="com.example.Controls.Wpf.Selection.ModernMultiSelectComboBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="320">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Field / collapsed view: comma-separated summary + chevron -->
            <ControlTemplate x:Key="FieldToggleTemplate" TargetType="ToggleButton">
                <Border x:Name="FocusRing"
                        CornerRadius="{StaticResource Radius.Md}"
                        BorderThickness="1"
                        BorderBrush="Transparent">
                    <Border x:Name="FieldBorder"
                            CornerRadius="{StaticResource Radius.Md}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource Brush.Border}"
                            Background="{StaticResource Brush.Surface}"
                            MinHeight="{StaticResource Size.ControlHeight}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="38" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="12,0,2,0">
                                <TextBlock x:Name="Placeholder"
                                           Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                           Foreground="{StaticResource Brush.TextPlaceholder}" FontStyle="Italic"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="Summary"
                                           Text="{Binding SummaryText, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Grid Grid.Column="1">
                                <Rectangle Width="1"
                                           HorizontalAlignment="Left"
                                           Fill="{StaticResource Brush.BorderSubtle}"
                                           Margin="0,9" />
                                <Path x:Name="Arrow"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Width="10" Height="6"
                                      Stretch="Uniform"
                                      Stroke="{StaticResource Brush.TextSecondary}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M1,1 L5,5 L9,1"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>
                <ControlTemplate.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=Summary}" Value="">
                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                    </Trigger>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter TargetName="FocusRing" Property="BorderBrush" Value="{StaticResource Brush.FocusRing}" />
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="FocusRing" Property="BorderBrush" Value="{StaticResource Brush.FocusRing}" />
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                        <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource Brush.Accent}" />
                        <Setter TargetName="Arrow" Property="RenderTransform">
                            <Setter.Value>
                                <RotateTransform Angle="180" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="FieldBorder" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                        <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                        <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource Brush.DisabledText}" />
                        <Setter TargetName="Summary" Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Dropdown row: a styled checkbox filling the whole row -->
            <Style x:Key="MultiSelectCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="Row"
                                    Background="Transparent"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Margin="4,1"
                                    Padding="{StaticResource Pad.Item}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="Box"
                                            Grid.Column="0"
                                            Width="18" Height="18"
                                            CornerRadius="{StaticResource Radius.Sm}"
                                            BorderThickness="1.5"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            Background="{StaticResource Brush.Surface}"
                                            VerticalAlignment="Center">
                                        <Path x:Name="CheckMark"
                                              Width="11" Height="8"
                                              Stretch="Uniform"
                                              Stroke="{StaticResource Brush.Surface}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M1,4.5 L4.5,8 L10,1"
                                              Visibility="Collapsed" />
                                    </Border>
                                    <ContentPresenter Grid.Column="1"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Box" Property="Background" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Style="{StaticResource Text.Label}"
                   Margin="{StaticResource Gap.Label}"
                   Text="{Binding Title, ElementName=RootControl}" />

        <Grid>
            <ToggleButton x:Name="DropToggle"
                          Template="{StaticResource FieldToggleTemplate}"
                          IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />

            <Popup x:Name="DropPopup"
                   PlacementTarget="{Binding ElementName=DropToggle}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   IsOpen="{Binding IsChecked, ElementName=DropToggle, Mode=TwoWay}"
                   Width="{Binding ActualWidth, ElementName=DropToggle}">
                <Border CornerRadius="{StaticResource Radius.Lg}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                        Background="{StaticResource Brush.Surface}"
                        Margin="0,6,0,8"
                        SnapsToDevicePixels="True"
                        Effect="{StaticResource Shadow.Popup}">
                    <ScrollViewer MaxHeight="260"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0,4">
                        <ItemsControl x:Name="ItemsHost">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource MultiSelectCheckBoxStyle}"
                                              Content="{Binding Display}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
    </StackPanel>

</UserControl>
