<UserControl x:Class="com.example.Controls.Wpf.Data.MatteDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="480" d:DesignHeight="260">
    <UserControl.Resources>

        <!-- Matte palette: muted stone neutrals, soft contrast, flat fills. -->
        <Style x:Key="MatteColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF2F2F0" />
            <Setter Property="Foreground" Value="#FF57534E" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="#FFE4E4E1" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style x:Key="MatteRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Foreground" Value="#FF44403C" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FFFAFAF9" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                        <Condition Property="IsSelected" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#FFF5F5F4" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Cell-level selection keeps the text readable: near-black on a muted
             stone fill, with a restrained accent indicator handled by the row. -->
        <Style x:Key="MatteCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF44403C" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE7E5E4" />
                    <Setter Property="Foreground" Value="#FF1C1917" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Border CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#FFE4E4E1"
            Background="#FFFFFFFF"
            ClipToBounds="True">
        <DataGrid x:Name="InnerDataGrid"
                  AutoGenerateColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FFEFEEEB"
                  VerticalGridLinesBrush="#FFEFEEEB"
                  BorderThickness="0"
                  Background="Transparent"
                  RowBackground="#FFFFFFFF"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  EnableRowVirtualization="True"
                  AlternationCount="2"
                  ColumnHeaderStyle="{StaticResource MatteColumnHeaderStyle}"
                  RowStyle="{StaticResource MatteRowStyle}"
                  CellStyle="{StaticResource MatteCellStyle}"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}" />
    </Border>

</UserControl>
