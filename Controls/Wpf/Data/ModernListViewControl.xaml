<UserControl x:Class="com.example.Controls.Wpf.Data.ModernListViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="480" d:DesignHeight="260">
    <UserControl.Resources>

        <Style x:Key="ModernGridViewHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FFF9FAFB" />
            <Setter Property="Foreground" Value="#FF374151" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="0,0,1,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="Transparent"
                                BorderBrush="#FFF1F2F4"
                                BorderThickness="0,0,0,1"
                                Padding="0,8">
                            <GridViewRowPresenter VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#FFF1F5FB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#FFEFF6FF" />
                                <Setter Property="Foreground" Value="#FF1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#FFE5E7EB"
            Background="#FFFFFFFF"
            ClipToBounds="True">
        <ListView x:Name="InnerListView"
                  BorderThickness="0"
                  Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ItemContainerStyle="{StaticResource ModernListViewItemStyle}"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}">
            <ListView.View>
                <GridView x:Name="MainGridView"
                          ColumnHeaderContainerStyle="{StaticResource ModernGridViewHeaderStyle}" />
            </ListView.View>
        </ListView>
    </Border>

</UserControl>
