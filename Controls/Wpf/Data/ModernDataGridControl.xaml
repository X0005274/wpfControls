<UserControl x:Class="com.example.Controls.Wpf.Data.ModernDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="480" d:DesignHeight="260">
    <UserControl.Resources>

        <Style x:Key="ModernColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF9FAFB" />
            <Setter Property="Foreground" Value="#FF374151" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style x:Key="ModernRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FFF9FAFB" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1F5FB" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFEFF6FF" />
                    <Setter Property="Foreground" Value="#FF1D4ED8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#FFE5E7EB"
            Background="#FFFFFFFF"
            ClipToBounds="True">
        <DataGrid x:Name="InnerDataGrid"
                  AutoGenerateColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FFF1F2F4"
                  VerticalGridLinesBrush="#FFF1F2F4"
                  BorderThickness="0"
                  Background="Transparent"
                  RowBackground="#FFFFFFFF"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  EnableRowVirtualization="True"
                  AlternationCount="2"
                  ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                  RowStyle="{StaticResource ModernRowStyle}"
                  CellStyle="{StaticResource ModernCellStyle}"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}" />
    </Border>

</UserControl>
