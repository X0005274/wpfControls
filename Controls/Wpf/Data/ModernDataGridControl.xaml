<UserControl x:Class="com.example.Controls.Wpf.Data.ModernDataGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="480" d:DesignHeight="260">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
                <ResourceDictionary Source="/com.example;component/Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="{StaticResource Radius.Lg}"
            BorderThickness="1"
            BorderBrush="{StaticResource Brush.Border}"
            Background="{StaticResource Brush.Surface}"
            ClipToBounds="True">
        <DataGrid x:Name="InnerDataGrid"
                  AutoGenerateColumns="True"
                  ColumnWidth="Auto"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                  VerticalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                  BorderThickness="0"
                  Background="Transparent"
                  RowBackground="{StaticResource Brush.Surface}"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  EnableRowVirtualization="True"
                  AlternationCount="2"
                  ColumnHeaderStyle="{StaticResource GridColumnHeaderStyle}"
                  RowStyle="{StaticResource GridRowStyle}"
                  CellStyle="{StaticResource GridCellStyle}"
                  ItemsSource="{Binding ItemsSource, ElementName=RootControl}"
                  SelectedItem="{Binding SelectedItem, ElementName=RootControl, Mode=TwoWay}"
                  IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}" />
    </Border>

</UserControl>
