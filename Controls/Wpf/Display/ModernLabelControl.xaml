<UserControl x:Class="com.example.Controls.Wpf.Display.ModernLabelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="{StaticResource Font.Family}"
             d:DesignWidth="280">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Text.Label}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock Text="*"
                       FontFamily="{StaticResource Font.Family}"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="{StaticResource Brush.ErrorBorder}"
                       Margin="3,0,0,0"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>
        <TextBlock Style="{StaticResource Text.Helper}"
                   Margin="{StaticResource Gap.Helper}"
                   Text="{Binding Description, ElementName=RootControl}" />
    </StackPanel>

</UserControl>
