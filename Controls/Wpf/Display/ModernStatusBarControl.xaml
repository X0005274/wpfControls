<UserControl x:Class="com.example.Controls.Wpf.Display.ModernStatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="360">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border x:Name="StatusBorder"
            CornerRadius="{StaticResource Radius.Md}"
            BorderThickness="1"
            BorderBrush="{StaticResource Brush.InfoBorder}"
            Background="{StaticResource Brush.InfoBackground}"
            Padding="12,8"
            MinHeight="36">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="Indicator"
                     Width="10" Height="10"
                     Fill="{StaticResource Brush.Accent}"
                     VerticalAlignment="Center" />
            <TextBlock x:Name="MessageText"
                       Text="{Binding StatusText, ElementName=RootControl}"
                       FontSize="{StaticResource Font.Size.Body}"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="10,0,0,0" />
        </StackPanel>
    </Border>

</UserControl>
