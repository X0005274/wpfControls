<UserControl x:Class="com.example.Controls.Wpf.Display.ModernChipControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             HorizontalAlignment="Left"
             VerticalAlignment="Center"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="90" d:DesignHeight="26">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 둥근 알약 모양 태그. 필요하면 오른쪽에 삭제(X) 버튼을 보여 줍니다. -->
    <Border CornerRadius="{StaticResource Radius.Pill}"
            Background="{StaticResource Brush.SelectedBackground}"
            Padding="10,3"
            HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding Text, ElementName=RootControl}"
                       FontSize="{StaticResource Font.Size.Label}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.SelectedText}" />
            <Button x:Name="RemoveButton"
                    Content="✕"
                    Margin="6,0,0,0"
                    Padding="0"
                    Width="14" Height="14"
                    FontSize="{StaticResource Font.Size.Micro}"
                    Cursor="Hand"
                    BorderThickness="0"
                    Background="Transparent"
                    Foreground="{StaticResource Brush.SelectedText}"
                    Click="RemoveButton_Click" />
        </StackPanel>
    </Border>
</UserControl>
