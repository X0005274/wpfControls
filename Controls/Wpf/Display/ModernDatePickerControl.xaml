<UserControl x:Class="com.example.Controls.Wpf.Display.ModernDatePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="280">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="{StaticResource Gap.Label}">
            <TextBlock Style="{StaticResource Text.Label}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock Text="*"
                       FontFamily="{DynamicResource Font.Family}"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="{StaticResource Brush.ErrorBorder}"
                       Margin="3,0,0,0"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border x:Name="FocusRing"
                CornerRadius="{StaticResource Radius.Md}"
                BorderThickness="1"
                BorderBrush="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusRing}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border x:Name="FieldBorder"
                    CornerRadius="{StaticResource Radius.Md}"
                    BorderThickness="1"
                    Padding="4,0"
                    MinHeight="{StaticResource Size.ControlHeight}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsEnabled, ElementName=InnerDatePicker}" Value="False">
                                <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DatePicker x:Name="InnerDatePicker"
                            BorderThickness="0"
                            Background="Transparent"
                            FontSize="13"
                            VerticalContentAlignment="Center"
                            SelectedDate="{Binding SelectedDate, ElementName=RootControl, Mode=TwoWay}"
                            IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
            </Border>
        </Border>

        <TextBlock Style="{StaticResource Text.Helper}"
                   Margin="{StaticResource Gap.Helper}"
                   Text="{Binding Description, ElementName=RootControl}" />
    </StackPanel>

</UserControl>
