<UserControl x:Class="com.example.Controls.Wpf.Display.ModernDatePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="280">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding Title, ElementName=RootControl}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FF1F2937"
                       Margin="0,0,0,4" />
            <TextBlock Text=" *"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FFDC2626"
                       Margin="0,0,0,4"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border x:Name="FieldBorder"
                CornerRadius="6"
                BorderThickness="1"
                Padding="4,2"
                MinHeight="36">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFFFFFFF" />
                    <Setter Property="BorderBrush" Value="#FFD1D5DB" />
                    <Style.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="#FF2563EB" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsEnabled, ElementName=InnerDatePicker}" Value="False">
                            <Setter Property="Background" Value="#FFF3F4F6" />
                            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
                            <Setter Property="Opacity" Value="0.75" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DatePicker x:Name="InnerDatePicker"
                        BorderThickness="0"
                        Background="Transparent"
                        FontSize="13"
                        VerticalContentAlignment="Center"
                        SelectedDate="{Binding SelectedDate, ElementName=RootControl, Mode=TwoWay}"
                        IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
        </Border>

        <TextBlock Text="{Binding Description, ElementName=RootControl}"
                   FontSize="11"
                   Foreground="#FF6B7280"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
    </StackPanel>

</UserControl>
