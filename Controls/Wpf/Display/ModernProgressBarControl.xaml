<UserControl x:Class="com.example.Controls.Wpf.Display.ModernProgressBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="320">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <Grid Margin="{StaticResource Gap.Label}">
            <TextBlock Style="{StaticResource Text.Label}"
                       HorizontalAlignment="Left"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock x:Name="PercentTextBlock"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Accent}"
                       HorizontalAlignment="Right"
                       Text="0%" />
        </Grid>

        <Border CornerRadius="5"
                Height="10"
                Background="{StaticResource Brush.BorderSubtle}"
                ClipToBounds="True">
            <ProgressBar x:Name="InnerProgressBar"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource Brush.Accent}"
                         Minimum="{Binding Minimum, ElementName=RootControl}"
                         Maximum="{Binding Maximum, ElementName=RootControl}"
                         Value="{Binding Value, ElementName=RootControl}"
                         IsIndeterminate="{Binding IsIndeterminate, ElementName=RootControl}" />
        </Border>
    </StackPanel>

</UserControl>
