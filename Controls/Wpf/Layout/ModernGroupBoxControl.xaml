<UserControl x:Class="com.example.Controls.Wpf.Layout.ModernGroupBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="360" d:DesignHeight="200">
    <Border CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#FFE5E7EB"
            Background="#FFFFFFFF">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="0,0,0,1"
                    Padding="14,10">
                <TextBlock Text="{Binding HeaderText, ElementName=RootControl}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FF1F2937" />
            </Border>

            <Border Grid.Row="1" Padding="14,12">
                <ContentPresenter Content="{Binding InnerContent, ElementName=RootControl}" />
            </Border>
        </Grid>
    </Border>

</UserControl>
