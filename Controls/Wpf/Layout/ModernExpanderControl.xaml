<UserControl x:Class="com.example.Controls.Wpf.Layout.ModernExpanderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="360">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="{StaticResource Radius.Lg}"
            BorderThickness="1"
            BorderBrush="{StaticResource Brush.BorderSubtle}"
            Background="{StaticResource Brush.Surface}"
            ClipToBounds="True">
        <StackPanel>
            <Border x:Name="HeaderBorder"
                    Background="{StaticResource Brush.Surface}"
                    Cursor="Hand"
                    Padding="14,12"
                    MouseLeftButtonUp="HeaderBorder_MouseLeftButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0"
                          Width="9" Height="9"
                          Stretch="Fill"
                          Fill="{StaticResource Brush.TextSecondary}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"
                          Data="M0,0 L4,4 L0,8 Z"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="ArrowRotation" Angle="0" />
                        </Path.RenderTransform>
                    </Path>

                    <TextBlock Grid.Column="1"
                               Style="{StaticResource Text.Title}"
                               FontSize="13"
                               Text="{Binding HeaderText, ElementName=RootControl}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border x:Name="ContentArea"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Border.LayoutTransform>
                    <ScaleTransform x:Name="ContentScale" ScaleY="0" />
                </Border.LayoutTransform>
                <ContentPresenter Content="{Binding InnerContent, ElementName=RootControl}" />
            </Border>
        </StackPanel>
    </Border>

</UserControl>
