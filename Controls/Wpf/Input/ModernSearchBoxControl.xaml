<UserControl x:Class="com.example.Controls.Wpf.Input.ModernSearchBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="360">
    <UserControl.Resources>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFEFF2F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border x:Name="FieldBorder"
            CornerRadius="6"
            BorderThickness="1"
            Padding="8,2"
            MinHeight="38">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#FFFFFFFF" />
                <Setter Property="BorderBrush" Value="#FFD1D5DB" />
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="#FF2563EB" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search glyph -->
            <Path Grid.Column="0"
                  Width="16" Height="16"
                  Margin="2,0,6,0"
                  VerticalAlignment="Center"
                  Stretch="Uniform"
                  Fill="#FF6B7280"
                  Data="M10,2 A6,6 0 1 0 10,14 A6,6 0 1 0 10,2 Z M14.5,14.5 L19,19" />

            <Grid Grid.Column="1">
                <TextBlock x:Name="PlaceholderLabel"
                           Text="{Binding PlaceholderText, ElementName=RootControl}"
                           Foreground="#FF9CA3AF"
                           FontSize="13"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=InnerTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox x:Name="InnerTextBox"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="13"
                         Foreground="#FF1F2937"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}"
                         KeyDown="InnerTextBox_KeyDown" />
            </Grid>

            <Button Grid.Column="2"
                    x:Name="ClearButton"
                    Click="ClearButton_Click"
                    ToolTip="Clear">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=InnerTextBox}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Width="12" Height="12"
                      Stretch="Uniform"
                      Stroke="#FF6B7280"
                      StrokeThickness="1.6"
                      Data="M2,2 L12,12 M12,2 L2,12" />
            </Button>

            <Button Grid.Column="3"
                    x:Name="SearchButton"
                    Style="{StaticResource IconButtonStyle}"
                    Click="SearchButton_Click"
                    ToolTip="Search"
                    IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}">
                <Path Width="16" Height="16"
                      Stretch="Uniform"
                      Fill="#FF2563EB"
                      Data="M10,2 A6,6 0 1 0 10,14 A6,6 0 1 0 10,2 Z M14.5,14.5 L19,19" />
            </Button>
        </Grid>
    </Border>

</UserControl>
