<UserControl x:Class="com.example.Controls.Wpf.Input.ModernSearchBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="360">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Radius.Sm}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border x:Name="FocusRing"
            CornerRadius="{StaticResource Radius.Md}"
            BorderThickness="1"
            BorderBrush="Transparent">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusRing}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Border x:Name="FieldBorder"
                CornerRadius="{StaticResource Radius.Md}"
                BorderThickness="1"
                Padding="8,0"
                MinHeight="{StaticResource Size.ControlHeight}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Width="16" Height="16"
                      Margin="2,0,6,0"
                      VerticalAlignment="Center"
                      Stretch="Uniform"
                      Fill="{StaticResource Brush.TextSecondary}"
                      Data="M10,2 A6,6 0 1 0 10,14 A6,6 0 1 0 10,2 Z M14.5,14.5 L19,19" />

                <Grid Grid.Column="1">
                    <TextBlock x:Name="PlaceholderLabel"
                               Text="{Binding PlaceholderText, ElementName=RootControl}"
                               Foreground="{StaticResource Brush.TextPlaceholder}"
                               FontSize="{StaticResource Font.Size.Body}"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InnerTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox x:Name="InnerTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="{StaticResource Font.Size.Body}"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             CaretBrush="{StaticResource Brush.TextPrimary}"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}"
                             KeyDown="InnerTextBox_KeyDown" />
                </Grid>

                <Button Grid.Column="2"
                        x:Name="ClearButton"
                        Click="ClearButton_Click"
                        ToolTip="Clear">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=InnerTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Width="12" Height="12"
                          Stretch="Uniform"
                          Stroke="{StaticResource Brush.TextSecondary}"
                          StrokeThickness="1.6"
                          Data="M2,2 L12,12 M12,2 L2,12" />
                </Button>

                <Button Grid.Column="3"
                        x:Name="SearchButton"
                        Style="{StaticResource IconButtonStyle}"
                        Click="SearchButton_Click"
                        ToolTip="Search"
                        IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}">
                    <Path Width="16" Height="16"
                          Stretch="Uniform"
                          Fill="{StaticResource Brush.Accent}"
                          Data="M10,2 A6,6 0 1 0 10,14 A6,6 0 1 0 10,2 Z M14.5,14.5 L19,19" />
                </Button>
            </Grid>
        </Border>
    </Border>

</UserControl>
