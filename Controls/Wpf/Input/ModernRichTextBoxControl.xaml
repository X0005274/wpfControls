<UserControl x:Class="com.example.Controls.Wpf.Input.ModernRichTextBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="360" d:DesignHeight="180">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="{StaticResource Gap.Label}">
            <TextBlock Style="{StaticResource Text.Label}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock Text="*"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="{StaticResource Brush.ErrorBorder}"
                       Margin="3,0,0,0"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border x:Name="FocusRing"
                Grid.Row="1"
                CornerRadius="{StaticResource Radius.Md}"
                BorderThickness="1"
                BorderBrush="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=InnerRichTextBox}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusRing}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border x:Name="FieldBorder"
                    CornerRadius="{StaticResource Radius.Md}"
                    BorderThickness="1"
                    MinHeight="120">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=InnerRichTextBox}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsReadOnly, ElementName=InnerRichTextBox}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEnabled, ElementName=InnerRichTextBox}" Value="False">
                                <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <RichTextBox x:Name="InnerRichTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="13"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             CaretBrush="{StaticResource Brush.TextPrimary}"
                             Padding="8"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}"
                             IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
            </Border>
        </Border>

        <TextBlock Grid.Row="2"
                   Style="{StaticResource Text.Helper}"
                   Margin="{StaticResource Gap.Helper}"
                   Text="{Binding Description, ElementName=RootControl}" />
    </Grid>

</UserControl>
