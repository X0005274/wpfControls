<UserControl x:Class="com.example.Controls.Wpf.Input.ModernRichTextBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="360" d:DesignHeight="180">
    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#FF6B7280" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Style="{StaticResource TitleTextStyle}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock Text=" *"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FFDC2626"
                       Margin="0,0,0,4"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border x:Name="FieldBorder"
                Grid.Row="1"
                CornerRadius="6"
                BorderThickness="1"
                MinHeight="120">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFFFFFFF" />
                    <Setter Property="BorderBrush" Value="#FFD1D5DB" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=InnerRichTextBox}" Value="True">
                            <Setter Property="BorderBrush" Value="#FF2563EB" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsReadOnly, ElementName=InnerRichTextBox}" Value="True">
                            <Setter Property="Background" Value="#FFF3F4F6" />
                            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEnabled, ElementName=InnerRichTextBox}" Value="False">
                            <Setter Property="Background" Value="#FFF3F4F6" />
                            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
                            <Setter Property="Opacity" Value="0.75" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <RichTextBox x:Name="InnerRichTextBox"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="13"
                         Foreground="#FF1F2937"
                         Padding="8"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}"
                         IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
        </Border>

        <TextBlock Grid.Row="2"
                   Style="{StaticResource DescriptionTextStyle}"
                   Text="{Binding Description, ElementName=RootControl}" />
    </Grid>

</UserControl>
