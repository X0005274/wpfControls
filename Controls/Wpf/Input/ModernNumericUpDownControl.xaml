<UserControl x:Class="com.example.Controls.Wpf.Input.ModernNumericUpDownControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 위/아래 증감 버튼(작은 정사각형) 스타일 -->
            <Style x:Key="SpinButtonStyle" TargetType="RepeatButton">
                <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <!-- 제목(선택): 값이 있으면 위에 작은 라벨로 표시(빈 값이면 코드에서 숨김) -->
        <TextBlock x:Name="TitleText"
                   Style="{StaticResource Text.Label}"
                   Margin="{StaticResource Gap.Label}"
                   Text="{Binding Title, ElementName=RootControl}" />

        <!-- 입력 영역: 숫자 텍스트 + 오른쪽 위/아래 버튼 -->
        <Border BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Md}"
                Background="{StaticResource Brush.Surface}"
                Height="{StaticResource Size.ControlHeight}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>

                <!-- 숫자 표시/편집 텍스트박스 -->
                <TextBox x:Name="ValueTextBox"
                         Grid.Column="0"
                         VerticalContentAlignment="Center"
                         Padding="12,0"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="{StaticResource Font.Size.Body}"
                         Foreground="{StaticResource Brush.TextPrimary}"
                         IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}"
                         PreviewTextInput="ValueTextBox_PreviewTextInput"
                         LostFocus="ValueTextBox_LostFocus"
                         KeyDown="ValueTextBox_KeyDown" />

                <!-- 위/아래 증감 버튼 -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <RepeatButton x:Name="UpButton" Grid.Row="0"
                                  Style="{StaticResource SpinButtonStyle}"
                                  Content="▲"
                                  IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}"
                                  Click="UpButton_Click" />
                    <RepeatButton x:Name="DownButton" Grid.Row="1"
                                  Style="{StaticResource SpinButtonStyle}"
                                  Content="▼"
                                  IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}"
                                  Click="DownButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
