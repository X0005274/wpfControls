<UserControl x:Class="com.example.Controls.Wpf.Input.ModernButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="120" d:DesignHeight="40">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 버튼 공통 스타일: 둥근 모서리 + 가운데 정렬 + 마우스 상태에 따른 색 변화.
                 종류(Primary/Secondary/Danger)별 색은 아래 DataTrigger로 바꿉니다. -->
            <Style x:Key="ModernButtonStyle" TargetType="Button">
                <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="{StaticResource Size.ControlHeight}" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <!-- 기본값(Primary): 파란 배경, 흰 글자 -->
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- 마우스를 올리면 살짝 어두운 강조색으로 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.92" />
                                </Trigger>
                                <!-- 비활성 상태: 흐리게 -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5" />
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- 보조 버튼: 흰 배경 + 회색 테두리 + 진한 글자 -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                    </DataTrigger>
                    <!-- 위험 버튼: 빨간 배경 + 흰 글자 -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Danger">
                        <Setter Property="Background" Value="{StaticResource Brush.ErrorBorder}" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.ErrorBorder}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 실제 버튼: 표시 글자(Text)와 클릭 이벤트를 바깥으로 노출합니다. -->
    <Button x:Name="InnerButton"
            Style="{StaticResource ModernButtonStyle}"
            Content="{Binding Text, ElementName=RootControl}"
            Click="InnerButton_Click" />
</UserControl>
