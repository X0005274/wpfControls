<UserControl x:Class="com.example.Controls.Wpf.Input.ModernButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="120" d:DesignHeight="40">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 버튼 공통 스타일: 둥근 모서리 + 가운데 정렬 + 마우스 상태에 따른 색 변화.
                 종류(Primary/Secondary/Danger)별 색은 아래 DataTrigger로 바꿉니다. -->
            <Style x:Key="ModernButtonStyle" TargetType="Button">
                <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="{StaticResource Size.ControlHeight}" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <!-- 기본값(Primary): 파란 배경, 흰 글자 -->
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- 비활성 상태: 흐리게 -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.5" />
                                    <Setter Property="Cursor" Value="Arrow" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- 보조 버튼: 흰 배경 + 회색 테두리 + 진한 글자 -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                    </DataTrigger>
                    <!-- 위험 버튼: 빨간 배경 + 흰 글자 -->
                    <DataTrigger Binding="{Binding Kind, ElementName=RootControl}" Value="Danger">
                        <Setter Property="Background" Value="{StaticResource Brush.ErrorBorder}" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.ErrorBorder}" />
                    </DataTrigger>

                    <!-- Primary: 호버=진한 파랑, 클릭=더 진한 파랑 -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Primary" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.AccentHover}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Primary" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.AccentPressed}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentPressed}" />
                    </MultiDataTrigger>

                    <!-- Secondary: 호버=옅은 파란 톤 + 파란 글자/테두리(포인트), 클릭=약간 더 진한 파랑 톤 -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.InfoBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Secondary" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.AccentHover}" />
                    </MultiDataTrigger>

                    <!-- Danger: 호버/클릭 시 더 진한 빨강 -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Danger" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.ErrorText}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.ErrorText}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding Kind, ElementName=RootControl}" Value="Danger" />
                            <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.DangerPressed}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.DangerPressed}" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 실제 버튼: 아이콘(선택) + 표시 글자(Text), 클릭 이벤트를 바깥으로 노출합니다. -->
    <Button x:Name="InnerButton"
            Style="{StaticResource ModernButtonStyle}"
            Click="InnerButton_Click">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{Binding IconGlyph, ElementName=RootControl}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IconGlyph, ElementName=RootControl}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding Text, ElementName=RootControl}" VerticalAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>
