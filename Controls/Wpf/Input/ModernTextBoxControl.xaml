<UserControl x:Class="com.example.Controls.Wpf.Input.ModernTextBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="320">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
                <ResourceDictionary Source="/com.example;component/Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>

        <StackPanel Orientation="Horizontal" Margin="{StaticResource Gap.Label}">
            <TextBlock Style="{StaticResource Text.Label}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock Style="{StaticResource RequiredMarkStyle}"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <!-- Outer focus ring (flat, no shadow) wraps the field border. -->
        <Border x:Name="FocusRing"
                CornerRadius="{StaticResource Radius.Md}"
                BorderThickness="1"
                BorderBrush="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFocused, ElementName=InnerTextBox}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusRing}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border x:Name="FieldBorder"
                    CornerRadius="{StaticResource Radius.Md}"
                    BorderThickness="1"
                    Padding="{StaticResource Pad.Field}"
                    MinHeight="{StaticResource Size.ControlHeight}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsFocused, ElementName=InnerTextBox}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.FocusBorder}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsReadOnly, ElementName=InnerTextBox}" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEnabled, ElementName=InnerTextBox}" Value="False">
                                <Setter Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock x:Name="PlaceholderLabel"
                               Text="{Binding PlaceholderText, ElementName=RootControl}"
                               Foreground="{StaticResource Brush.TextPlaceholder}" FontStyle="Italic"
                               FontSize="{StaticResource Font.Size.Body}"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InnerTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox x:Name="InnerTextBox"
                             Style="{StaticResource FieldInnerTextBoxStyle}"
                             Text="{Binding Text, ElementName=RootControl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsReadOnly, ElementName=RootControl}"
                             IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
                </Grid>
            </Border>
        </Border>

        <TextBlock Style="{StaticResource Text.Helper}"
                   Margin="{StaticResource Gap.Helper}"
                   Text="{Binding Description, ElementName=RootControl}" />

    </StackPanel>

</UserControl>
