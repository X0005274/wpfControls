<UserControl x:Class="com.example.Controls.Wpf.Input.ModernCurrencyBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="240">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="{StaticResource Gap.Label}">
            <TextBlock x:Name="TitleText"
                       Style="{StaticResource Text.Label}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock x:Name="RequiredMark"
                       Text="*"
                       FontFamily="{DynamicResource Font.Family}"
                       FontSize="{StaticResource Font.Size.Label}" FontWeight="Medium"
                       Foreground="{StaticResource Brush.ErrorBorder}"
                       Margin="3,0,0,0" />
        </StackPanel>

        <Border BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Md}"
                Background="{StaticResource Brush.Surface}"
                Height="{StaticResource Size.ControlHeight}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 통화 기호(예: ₩) -->
                <TextBlock x:Name="PrefixText" Grid.Column="0"
                           Text="{Binding Prefix, ElementName=RootControl}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="{StaticResource Font.Size.Body}"
                           VerticalAlignment="Center"
                           Margin="12,0,4,0" />

                <!-- 금액 입력(오른쪽 정렬) -->
                <TextBox x:Name="InnerTextBox" Grid.Column="1"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Right"
                         Padding="0,0,12,0"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="{StaticResource Font.Size.Body}"
                         Foreground="{StaticResource Brush.TextPrimary}"
                         IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}"
                         PreviewTextInput="InnerTextBox_PreviewTextInput"
                         TextChanged="InnerTextBox_TextChanged" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
