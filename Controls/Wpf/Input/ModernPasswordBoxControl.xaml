<UserControl x:Class="com.example.Controls.Wpf.Input.ModernPasswordBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="RootControl"
             FontFamily="Segoe UI"
             d:DesignWidth="320">
    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF1F2937" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#FF6B7280" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ToggleEyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FF6B7280" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF2563EB" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <StackPanel>

        <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource TitleTextStyle}"
                       Text="{Binding Title, ElementName=RootControl}" />
            <TextBlock Text=" *"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#FFDC2626"
                       Margin="0,0,0,4"
                       Visibility="{Binding IsRequired, ElementName=RootControl, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <Border x:Name="FieldBorder"
                CornerRadius="6"
                BorderThickness="1"
                Padding="10,8"
                MinHeight="36">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFFFFFFF" />
                    <Setter Property="BorderBrush" Value="#FFD1D5DB" />
                    <Style.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="#FF2563EB" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsEnabled, ElementName=PwBox}" Value="False">
                            <Setter Property="Background" Value="#FFF3F4F6" />
                            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
                            <Setter Property="Opacity" Value="0.75" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <PasswordBox x:Name="PwBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="13"
                                 Foreground="#FF1F2937"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PwBox_PasswordChanged"
                                 IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
                    <TextBox x:Name="PlainBox"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="13"
                             Foreground="#FF1F2937"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"
                             TextChanged="PlainBox_TextChanged"
                             IsEnabled="{Binding IsEditorEnabled, ElementName=RootControl}" />
                </Grid>

                <Button Grid.Column="1"
                        x:Name="ToggleButton"
                        Style="{StaticResource ToggleEyeButtonStyle}"
                        Content="Show"
                        Click="ToggleButton_Click" />
            </Grid>
        </Border>

        <TextBlock Style="{StaticResource DescriptionTextStyle}"
                   Text="{Binding Description, ElementName=RootControl}" />

    </StackPanel>

</UserControl>
