<UserControl x:Class="com.example.Controls.Wpf.Screens.EmployeeManagementScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="1040" d:DesignHeight="680">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Primary action button -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.AccentHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary / ghost button -->
            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.HoverBackground}" />
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{StaticResource Brush.BorderHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Filter field label -->
            <Style x:Key="FilterLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource Text.Label}">
                <Setter Property="Margin" Value="{StaticResource Gap.Label}" />
            </Style>

            <!-- Filter text input -->
            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Style>

            <!-- Filter combo input -->
            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Column header look -->
            <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.HeaderBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>

            <Style x:Key="GridRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver" Value="True" />
                            <Condition Property="IsSelected" Value="False" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                    </MultiTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GridCellStyle" TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="{StaticResource Pad.Item}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- DatePicker: vertically center the date text and drop the default
                 top-aligned watermark template so it matches the other inputs.
                 Implicit (no key) so the DatePicker's inner text box picks it up. -->
            <Style TargetType="DatePickerTextBox">
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="2,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePickerTextBox">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DatePicker outer look: 36px tall, consistent border, padded. -->
            <Style x:Key="DatePickerStyle" TargetType="DatePicker">
                <Setter Property="Height" Value="36" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Padding" Value="6,0" />
            </Style>

            <!-- Form field label -->
            <Style x:Key="FormLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource Text.Label}">
                <Setter Property="Margin" Value="{StaticResource Gap.Label}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">

      <!-- ===== List page ===== -->
      <Grid x:Name="ListPage">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. Page header: title + actions -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="직원관리"
                       VerticalAlignment="Center"
                       FontFamily="{DynamicResource Font.Family}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="ExcelDownloadButton"
                        Style="{StaticResource GhostButtonStyle}"
                        Content="엑셀다운로드"
                        IsEnabled="False"
                        ToolTip="후속 작업 예정" />
                <Button x:Name="CreateButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="신규등록"
                        Margin="8,0,0,0"
                        ToolTip="직원 등록"
                        Click="CreateButton_Click" />
            </StackPanel>
        </Grid>

        <!-- 2. Search filter bar -->
        <Border Grid.Row="1"
                Margin="0,0,0,16"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="사번/이름" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="KeywordBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="부서코드" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="DepartmentCodeBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="재직상태" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="EmploymentStatusCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="전체" />
                            <ComboBoxItem Content="재직" />
                            <ComboBoxItem Content="휴직" />
                            <ComboBoxItem Content="퇴직" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="고용형태" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="EmploymentTypeCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="전체" />
                            <ComboBoxItem Content="정규직" />
                            <ComboBoxItem Content="계약직" />
                            <ComboBoxItem Content="임시직" />
                            <ComboBoxItem Content="시간제" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="입사일(시작)" Style="{StaticResource FilterLabelStyle}" />
                        <DatePicker x:Name="HireDateFromPicker" Style="{StaticResource DatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="입사일(종료)" Style="{StaticResource FilterLabelStyle}" />
                        <DatePicker x:Name="HireDateToPicker" Style="{StaticResource DatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="사업장코드" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="SiteCodeBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>
                </WrapPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ResetButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="초기화"
                            Click="ResetButton_Click" />
                    <Button x:Name="SearchButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="검색"
                            Margin="8,0,0,0"
                            Click="SearchButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3. Result count -->
        <TextBlock Grid.Row="2" Margin="2,0,0,8">
            <Run Text="총 " Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" />
            <Run x:Name="TotalCountRun" Text="0" Foreground="{StaticResource Brush.TextPrimary}" FontSize="13" FontWeight="SemiBold" />
            <Run Text="명" Foreground="{StaticResource Brush.TextSecondary}" FontSize="13" />
        </TextBlock>

        <!-- 4. Employee table -->
        <Border Grid.Row="3"
                CornerRadius="{StaticResource Radius.Lg}"
                BorderThickness="1"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                Background="{StaticResource Brush.Surface}"
                ClipToBounds="True">
            <DataGrid x:Name="EmployeeGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                      VerticalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="{StaticResource Brush.Surface}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      EnableRowVirtualization="True"
                      AlternationCount="2"
                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                      RowStyle="{StaticResource GridRowStyle}"
                      CellStyle="{StaticResource GridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="사번" Binding="{Binding EmployeeId}" Width="100" />
                    <DataGridTextColumn Header="이름" Binding="{Binding EmployeeName}" Width="120" />
                    <DataGridTextColumn Header="부서" Binding="{Binding DepartmentName}" Width="*" />
                    <DataGridTextColumn Header="직급/직책" Binding="{Binding PositionName}" Width="*" />
                    <DataGridTextColumn Header="고용형태" Binding="{Binding EmploymentType}" Width="110" />
                    <DataGridTextColumn Header="입사일" Binding="{Binding HireDate}" Width="120" />
                    <DataGridTextColumn Header="재직상태" Binding="{Binding EmploymentStatus}" Width="100" />
                    <DataGridTextColumn Header="급여대상" Binding="{Binding PayrollTarget}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 5. Pagination -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">
            <Button x:Name="PrevPageButton"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="이전"
                    IsEnabled="False" />
            <TextBlock x:Name="PageInfoText"
                       Text="1 / 1"
                       VerticalAlignment="Center"
                       Margin="16,0"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextSecondary}" />
            <Button x:Name="NextPageButton"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="다음"
                    IsEnabled="False" />
        </StackPanel>
      </Grid>
      <!-- ===== End list page ===== -->

      <!-- ===== Create page (직원 신규등록) ===== -->
      <Grid x:Name="CreatePage" Visibility="Collapsed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Create header -->
        <TextBlock Grid.Row="0"
                   Text="직원 신규등록"
                   Margin="0,0,0,16"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}" />

        <!-- Form -->
        <Border Grid.Row="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel Orientation="Horizontal">
                    <!-- 사번 * (with helper buttons) -->
                    <StackPanel Width="436" Margin="0,0,16,16">
                        <TextBlock Text="사번 *" Style="{StaticResource FormLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="NewIdBox" Style="{StaticResource FilterInputStyle}" />
                            <Button Grid.Column="1" x:Name="CheckIdButton"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Content="중복확인" Margin="8,0,0,0"
                                    Click="CheckIdButton_Click" />
                            <Button Grid.Column="2" x:Name="SuggestIdButton"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Content="다음 사번" Margin="8,0,0,0"
                                    Click="SuggestIdButton_Click" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="이름 *" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="NewNameBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="부서 *" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox x:Name="NewDeptCombo" Style="{StaticResource FilterComboStyle}" SelectedIndex="0">
                            <ComboBoxItem Content="선택" />
                            <ComboBoxItem Content="인사팀" />
                            <ComboBoxItem Content="재무팀" />
                            <ComboBoxItem Content="개발팀" />
                            <ComboBoxItem Content="영업팀" />
                            <ComboBoxItem Content="총무팀" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="직급/직책" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox x:Name="NewPositionCombo" Style="{StaticResource FilterComboStyle}" SelectedIndex="0">
                            <ComboBoxItem Content="선택" />
                            <ComboBoxItem Content="사원" />
                            <ComboBoxItem Content="대리" />
                            <ComboBoxItem Content="과장" />
                            <ComboBoxItem Content="차장" />
                            <ComboBoxItem Content="부장" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="고용형태 *" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox x:Name="NewTypeCombo" Style="{StaticResource FilterComboStyle}" SelectedIndex="0">
                            <ComboBoxItem Content="선택" />
                            <ComboBoxItem Content="정규직" />
                            <ComboBoxItem Content="계약직" />
                            <ComboBoxItem Content="임시직" />
                            <ComboBoxItem Content="시간제" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="입사일 *" Style="{StaticResource FormLabelStyle}" />
                        <DatePicker x:Name="NewHireDatePicker" Style="{StaticResource DatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="재직상태" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox x:Name="NewStatusCombo" Style="{StaticResource FilterComboStyle}" SelectedIndex="0">
                            <ComboBoxItem Content="재직" />
                            <ComboBoxItem Content="휴직" />
                            <ComboBoxItem Content="퇴직" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="계좌번호" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="NewBankBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="세금구분" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="NewTaxBox" Style="{StaticResource FilterInputStyle}" Text="GENERAL" />
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="부양가족수(본인 포함)" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="NewDependentBox" Style="{StaticResource FilterInputStyle}" Text="1" />
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="이메일" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="NewEmailBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16">
                        <TextBlock Text="연락처" Style="{StaticResource FormLabelStyle}" />
                        <TextBox x:Name="NewPhoneBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>

                    <StackPanel Width="436" Margin="0,0,16,16">
                        <TextBlock Text="사진 (로컬 파일 선택, 600KB 이하)" Style="{StaticResource FormLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="PhotoButton"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Content="파일 선택"
                                    Click="PhotoButton_Click" />
                            <TextBlock Grid.Column="1" x:Name="PhotoNameText"
                                       Text="선택된 파일 없음"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Width="260" Margin="0,0,16,16" VerticalAlignment="Bottom">
                        <CheckBox x:Name="NewPayrollCheck"
                                  Content="급여대상 포함"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="{StaticResource Brush.TextPrimary}"
                                  Margin="0,0,0,8" />
                    </StackPanel>
                </WrapPanel>
            </ScrollViewer>
        </Border>

        <!-- Create actions -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelCreateButton"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="취소"
                    Click="CancelCreateButton_Click" />
            <Button x:Name="SaveCreateButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="직원 등록"
                    Margin="8,0,0,0"
                    Click="SaveCreateButton_Click" />
        </StackPanel>
      </Grid>
      <!-- ===== End create page ===== -->

    </Grid>
</UserControl>
