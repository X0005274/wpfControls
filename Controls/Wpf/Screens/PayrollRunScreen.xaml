<UserControl x:Class="com.example.Controls.Wpf.Screens.PayrollRunScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:display="clr-namespace:com.example.Controls.Wpf.Display"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="1040" d:DesignHeight="820">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.AccentHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.BorderHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource Text.Label}">
                <Setter Property="Margin" Value="{StaticResource Gap.Label}" />
            </Style>
            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Style>
            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <Style x:Key="CardTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>


            <!-- KPI card -->
            <Style x:Key="KpiCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="Margin" Value="0,0,12,0" />
            </Style>
            <Style x:Key="KpiLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>
            <Style x:Key="KpiValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Style>

            <!-- Result grid styles -->
            <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.HeaderBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>
            <Style x:Key="NumHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeaderStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
            </Style>
            <Style x:Key="GridRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver" Value="True" />
                            <Condition Property="IsSelected" Value="False" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
                    </MultiTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="GridCellStyle" TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="{StaticResource Pad.Item}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
                        <Setter Property="FontWeight" Value="Medium" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="NumCellTextStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>

            <!-- Payslip line row -->
            <Style x:Key="LineNameStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Style>
            <Style x:Key="LineAmountStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">

      <!-- ===== Main page ===== -->
      <Grid x:Name="MainPage">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="급여계산"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.PageTitle}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <Button Grid.Column="1"
                    x:Name="CreateButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="신규등록"
                    ToolTip="급여 회차 등록"
                    Click="CreateButton_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- 1. 조건 바 -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <StackPanel Width="180" Margin="0,0,12,0">
                                <TextBlock Text="급여그룹" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox x:Name="PayrollGroupBox" Style="{StaticResource FilterInputStyle}" Text="MONTHLY" />
                            </StackPanel>
                            <StackPanel Width="180" Margin="0,0,12,0">
                                <TextBlock Text="사업장코드" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox x:Name="SiteCodeBox" Style="{StaticResource FilterInputStyle}" />
                            </StackPanel>
                            <StackPanel Width="160" Margin="0,0,12,0">
                                <TextBlock Text="계산구분" Style="{StaticResource FilterLabelStyle}" />
                                <ComboBox x:Name="RunTypeCombo" Style="{StaticResource FilterComboStyle}" SelectedValuePath="Code" />
                            </StackPanel>
                        </WrapPanel>
                        <Button Grid.Column="1"
                                x:Name="ApplyButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="조회"
                                VerticalAlignment="Bottom"
                                Click="ApplyButton_Click" />
                    </Grid>
                </Border>

                <!-- 2. 진행 상태 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="진행 상태" Style="{StaticResource CardTitleStyle}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="현재 상태"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       FontSize="{StaticResource Font.Size.Label}"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                            <display:ModernBadgeControl x:Name="CurrentStatusBadge" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel x:Name="ProgressSteps" Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Step1Dot" Width="12" Height="12" />
                                <TextBlock x:Name="Step1Label" Text="데이터마감" Margin="6,0,0,0" FontSize="{StaticResource Font.Size.Label}" VerticalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Width="28" Height="2" Margin="10,0" VerticalAlignment="Center" Fill="{StaticResource Brush.BorderSubtle}" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Step2Dot" Width="12" Height="12" />
                                <TextBlock x:Name="Step2Label" Text="계산완료" Margin="6,0,0,0" FontSize="{StaticResource Font.Size.Label}" VerticalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Width="28" Height="2" Margin="10,0" VerticalAlignment="Center" Fill="{StaticResource Brush.BorderSubtle}" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Step3Dot" Width="12" Height="12" />
                                <TextBlock x:Name="Step3Label" Text="검토완료" Margin="6,0,0,0" FontSize="{StaticResource Font.Size.Label}" VerticalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Width="28" Height="2" Margin="10,0" VerticalAlignment="Center" Fill="{StaticResource Brush.BorderSubtle}" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Step4Dot" Width="12" Height="12" />
                                <TextBlock x:Name="Step4Label" Text="승인요청" Margin="6,0,0,0" FontSize="{StaticResource Font.Size.Label}" VerticalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Width="28" Height="2" Margin="10,0" VerticalAlignment="Center" Fill="{StaticResource Brush.BorderSubtle}" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Step5Dot" Width="12" Height="12" />
                                <TextBlock x:Name="Step5Label" Text="마감완료" Margin="6,0,0,0" FontSize="{StaticResource Font.Size.Label}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 3. 요약 카드 -->
                <UniformGrid Rows="1" Columns="5" Margin="0,0,0,16">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="대상자 수" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="SumTargetText" Text="0명" Style="{StaticResource KpiValueStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="총지급액" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="SumGrossText" Text="₩0" Style="{StaticResource KpiValueStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="총공제액" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="SumDeductionText" Text="₩0" Style="{StaticResource KpiValueStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="실지급액" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="SumNetText" Text="₩0" Style="{StaticResource KpiValueStyle}" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="SumErrorCard" Style="{StaticResource KpiCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="오류건수" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="SumErrorText" Text="0건" Style="{StaticResource KpiValueStyle}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- 4. 계산 결과 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="계산 결과" Style="{StaticResource CardTitleStyle}" />
                        <Grid>
                            <Border CornerRadius="{StaticResource Radius.Md}"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                                    ClipToBounds="True">
                                <DataGrid x:Name="ResultGrid"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          RowBackground="{StaticResource Brush.Surface}"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          AlternationCount="2"
                                          MaxHeight="260"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          CellStyle="{StaticResource GridCellStyle}"
                                          SelectionChanged="ResultGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="사번" Binding="{Binding EmployeeId}" Width="90" />
                                        <DataGridTextColumn Header="이름" Binding="{Binding EmployeeName}" Width="100" />
                                        <DataGridTextColumn Header="부서" Binding="{Binding DepartmentName}" Width="*" />
                                        <DataGridTextColumn Header="기본급" Binding="{Binding BaseSalaryText}" Width="120"
                                                            ElementStyle="{StaticResource NumCellTextStyle}"
                                                            HeaderStyle="{StaticResource NumHeaderStyle}" />
                                        <DataGridTextColumn Header="수당합계" Binding="{Binding AllowanceText}" Width="120"
                                                            ElementStyle="{StaticResource NumCellTextStyle}"
                                                            HeaderStyle="{StaticResource NumHeaderStyle}" />
                                        <DataGridTextColumn Header="공제합계" Binding="{Binding DeductionText}" Width="120"
                                                            ElementStyle="{StaticResource NumCellTextStyle}"
                                                            HeaderStyle="{StaticResource NumHeaderStyle}" />
                                        <DataGridTextColumn Header="실지급액" Binding="{Binding NetPayText}" Width="120"
                                                            ElementStyle="{StaticResource NumCellTextStyle}"
                                                            HeaderStyle="{StaticResource NumHeaderStyle}" />
                                        <DataGridTemplateColumn Header="계산상태" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <display:ModernBadgeControl BadgeText="{Binding CalcStatusLabel}" BadgeType="{Binding CalcStatusTone}" VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <TextBlock x:Name="ResultEmptyText"
                                       Text="계산 결과가 없습니다. 데이터마감 후 계산실행을 진행하면 결과가 표시됩니다."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,40"
                                       FontSize="{StaticResource Font.Size.Body}"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 5. 급여 명세 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="급여 명세 (항목별 내역)" VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.BodyLg}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="PdfButton"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Content="급여명세서(PDF)"
                                        Height="32"
                                        IsEnabled="False"
                                        Click="PdfButton_Click" />
                                <Button x:Name="EmailButton"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Content="이메일 발송"
                                        Height="32"
                                        Margin="8,0,0,0"
                                        IsEnabled="False"
                                        Click="EmailButton_Click" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="DetailHint"
                                   Text="결과 행을 선택하면 지급/공제 항목별 내역(4대보험·세금 포함)이 표시됩니다."
                                   FontSize="{StaticResource Font.Size.Body}"
                                   Foreground="{StaticResource Brush.TextSecondary}" />

                        <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                            <TextBlock x:Name="DetailSubjectText"
                                       FontSize="{StaticResource Font.Size.BodyLg}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 지급 항목 -->
                                <Border Grid.Column="0" Margin="0,0,8,0"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Md}">
                                    <StackPanel>
                                        <Grid Background="{StaticResource Brush.HeaderBackground}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="지급 항목" Padding="12,8" FontSize="{StaticResource Font.Size.Label}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" />
                                            <TextBlock Grid.Column="1" Text="금액" Padding="12,8" FontSize="{StaticResource Font.Size.Label}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" />
                                        </Grid>
                                        <ItemsControl x:Name="EarningsItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="12,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ItemName}" Style="{StaticResource LineNameStyle}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource LineAmountStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="0,1,0,0">
                                            <Grid Margin="12,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="합계" FontSize="{StaticResource Font.Size.Body}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" />
                                                <TextBlock Grid.Column="1" x:Name="EarningTotalText" FontSize="{StaticResource Font.Size.Body}" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource Brush.TextPrimary}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 공제 항목 -->
                                <Border Grid.Column="1" Margin="8,0,0,0"
                                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Md}">
                                    <StackPanel>
                                        <Grid Background="{StaticResource Brush.HeaderBackground}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="공제 항목" Padding="12,8" FontSize="{StaticResource Font.Size.Label}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" />
                                            <TextBlock Grid.Column="1" Text="금액" Padding="12,8" FontSize="{StaticResource Font.Size.Label}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextSecondary}" />
                                        </Grid>
                                        <ItemsControl x:Name="DeductionsItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="12,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ItemName}" Style="{StaticResource LineNameStyle}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource LineAmountStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border BorderBrush="{StaticResource Brush.BorderSubtle}" BorderThickness="0,1,0,0">
                                            <Grid Margin="12,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="합계" FontSize="{StaticResource Font.Size.Body}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" />
                                                <TextBlock Grid.Column="1" x:Name="DeductionTotalText" FontSize="{StaticResource Font.Size.Body}" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource Brush.TextPrimary}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Background="{StaticResource Brush.InfoBackground}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="14,10"
                                    Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="실지급액" VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Body}" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" />
                                    <TextBlock Grid.Column="1" x:Name="DetailNetText" FontSize="{StaticResource Font.Size.Subtitle}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 6. 액션 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="액션" Style="{StaticResource CardTitleStyle}" />
                        <WrapPanel Orientation="Horizontal">
                            <Button x:Name="CloseInputButton" Style="{StaticResource GhostButtonStyle}" Content="데이터마감" Margin="0,0,8,0" Click="CloseInputButton_Click" />
                            <Button x:Name="CalculateButton" Style="{StaticResource PrimaryButtonStyle}" Content="계산실행" Margin="0,0,8,0" Click="CalculateButton_Click" />
                            <Button x:Name="RecalculateButton" Style="{StaticResource GhostButtonStyle}" Content="재계산" Margin="0,0,8,0" Click="RecalculateButton_Click" />
                            <Button x:Name="RequestApprovalButton" Style="{StaticResource PrimaryButtonStyle}" Content="승인요청" Margin="0,0,8,0" Click="RequestApprovalButton_Click" />
                            <Button x:Name="FinalizeButton" Style="{StaticResource PrimaryButtonStyle}" Content="마감처리" Margin="0,0,8,0" Click="FinalizeButton_Click" />
                            <Button x:Name="ReviewErrorsButton" Style="{StaticResource GhostButtonStyle}" Content="오류검토" Visibility="Collapsed" Click="ReviewErrorsButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
      </Grid>
      <!-- ===== End main page ===== -->

      <!-- ===== Create page (급여 회차 등록) ===== -->
      <Grid x:Name="CreatePage" Visibility="Collapsed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="급여 회차 등록"
                   Margin="0,0,0,16"
                   FontSize="{StaticResource Font.Size.PageTitle}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}" />

        <Border Grid.Row="1"
                VerticalAlignment="Top"
                Style="{StaticResource CardStyle}">
            <StackPanel>
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Width="220" Margin="0,0,16,16">
                        <TextBlock Text="급여월 *" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="NewMonthBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>
                    <StackPanel Width="220" Margin="0,0,16,16">
                        <TextBlock Text="급여그룹 *" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="NewGroupBox" Style="{StaticResource FilterInputStyle}" Text="MONTHLY" />
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,16,16">
                        <TextBlock Text="계산구분 *" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="NewRunTypeCombo" Style="{StaticResource FilterComboStyle}" SelectedValuePath="Code" />
                    </StackPanel>
                </WrapPanel>
                <TextBlock Text="등록 직후 상태는 '준비중'이며, 이후 액션(데이터마감 → 계산실행 …)으로 전이됩니다."
                           FontSize="{StaticResource Font.Size.Label}"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelCreateButton"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="취소"
                    Click="CancelCreateButton_Click" />
            <Button x:Name="SaveCreateButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="회차 등록"
                    Margin="8,0,0,0"
                    Click="SaveCreateButton_Click" />
        </StackPanel>
      </Grid>
      <!-- ===== End create page ===== -->

    </Grid>
</UserControl>
