<UserControl x:Class="com.example.Controls.Wpf.Screens.ApprovalExceptionScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:display="clr-namespace:com.example.Controls.Wpf.Display"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="1040" d:DesignHeight="720">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Primary action button -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.AccentHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary / ghost button -->
            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.HoverBackground}" />
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{StaticResource Brush.BorderHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.DisabledBackground}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.DisabledText}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource Text.Label}">
                <Setter Property="Margin" Value="{StaticResource Gap.Label}" />
            </Style>

            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            </Style>

            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Card title -->
            <Style x:Key="CardTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <!-- Exception list item container: selectable card -->
            <Style x:Key="ExceptionItemStyle" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    Background="{StaticResource Brush.Surface}"
                                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="12,10">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.HoverBackground}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource Brush.SelectedBackground}" />
                                    <Setter TargetName="Bd" Property="BorderBrush"
                                            Value="{StaticResource Brush.Accent}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Detail key/value row -->
            <Style x:Key="DetailKeyStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                <Setter Property="Margin" Value="0,0,0,2" />
            </Style>
            <Style x:Key="DetailValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <!-- Audit log grid styles -->
            <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.HeaderBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>
            <Style x:Key="GridRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="GridCellStyle" TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="{StaticResource Pad.Item}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. Header: title + 신규등록 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="승인·예외처리"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.PageTitle}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <Button Grid.Column="1"
                    x:Name="CreateButton"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="신규등록"
                    ToolTip="예외 등록"
                    Click="CreateButton_Click" />
        </Grid>

        <!-- 2. Search filter bar -->
        <Border Grid.Row="1"
                Margin="0,0,0,16"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <WrapPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="부서코드" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="DepartmentCodeBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>
                    <StackPanel Width="200" Margin="0,0,12,12">
                        <TextBlock Text="예외유형" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="ExceptionTypeCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="전체" />
                            <ComboBoxItem Content="근태 누락" />
                            <ComboBoxItem Content="승인 안 된 연장근무" />
                            <ComboBoxItem Content="계좌정보 오류" />
                            <ComboBoxItem Content="공제정보 누락/불일치" />
                            <ComboBoxItem Content="음수/비정상 금액" />
                            <ComboBoxItem Content="퇴직자/휴직자 포함 오류" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Width="140" Margin="0,0,12,12">
                        <TextBlock Text="심각도" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="SeverityCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="전체" />
                            <ComboBoxItem Content="경미" />
                            <ComboBoxItem Content="중간" />
                            <ComboBoxItem Content="높음" />
                            <ComboBoxItem Content="치명" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Width="140" Margin="0,0,12,12">
                        <TextBlock Text="처리상태" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="StatusCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="전체" />
                            <ComboBoxItem Content="미처리" />
                            <ComboBoxItem Content="검토중" />
                            <ComboBoxItem Content="처리완료" />
                            <ComboBoxItem Content="반려" />
                            <ComboBoxItem Content="보류" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,12">
                        <TextBlock Text="사번/이름" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="KeywordBox" Style="{StaticResource FilterInputStyle}" />
                    </StackPanel>
                </WrapPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ResetButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="초기화"
                            Click="ResetButton_Click" />
                    <Button x:Name="SearchButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="검색"
                            Margin="8,0,0,0"
                            Click="SearchButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3. Board: 목록 / 상세 / 조치 -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- 예외 목록 -->
            <Border Grid.Column="0"
                    Margin="0,0,16,0"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Lg}"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="예외 목록" Style="{StaticResource CardTitleStyle}" />
                    <Grid>
                        <ListBox x:Name="ExceptionListBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource ExceptionItemStyle}"
                                 SelectionChanged="ExceptionListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding NameWithId}"
                                                       FontSize="{StaticResource Font.Size.Body}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.TextPrimary}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <display:ModernBadgeControl Grid.Column="1"
                                                    BadgeText="{Binding SeverityLabel}"
                                                    BadgeType="{Binding SeverityTone}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TypeLabel}"
                                                       FontSize="{StaticResource Font.Size.Label}"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <display:ModernBadgeControl Grid.Column="1"
                                                    BadgeText="{Binding StatusLabel}"
                                                    BadgeType="{Binding StatusTone}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="ListEmptyText"
                                   Text="예외가 없습니다."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,24,0,0"
                                   FontSize="{StaticResource Font.Size.Body}"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </Grid>
                </DockPanel>
            </Border>

            <!-- 상세 -->
            <Border Grid.Column="1"
                    Margin="0,0,16,0"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Lg}"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="상세" Style="{StaticResource CardTitleStyle}" />

                    <!-- Empty state -->
                    <StackPanel x:Name="DetailEmptyPanel"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="예외를 선택하세요."
                                   FontSize="{StaticResource Font.Size.BodyLg}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="좌측 목록에서 처리할 예외를 선택하면 상세가 표시됩니다."
                                   FontSize="{StaticResource Font.Size.Label}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource Brush.TextSecondary}" />
                    </StackPanel>

                    <!-- Detail content -->
                    <ScrollViewer x:Name="DetailContent"
                                  Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="DetailName"
                                               FontSize="{StaticResource Font.Size.Title}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextPrimary}" />
                                    <TextBlock x:Name="DetailType"
                                               FontSize="{StaticResource Font.Size.Label}"
                                               Margin="0,2,0,0"
                                               Foreground="{StaticResource Brush.TextSecondary}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <display:ModernBadgeControl x:Name="DetailSeverityBadge" VerticalAlignment="Center" />
                                    <display:ModernBadgeControl x:Name="DetailStatusBadge" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="원인" Style="{StaticResource DetailKeyStyle}" />
                            <TextBlock x:Name="DetailReason" Style="{StaticResource DetailValueStyle}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="변경 전 값" Style="{StaticResource DetailKeyStyle}" />
                                    <TextBlock x:Name="DetailBefore" Style="{StaticResource DetailValueStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="변경 후 값" Style="{StaticResource DetailKeyStyle}" />
                                    <TextBlock x:Name="DetailAfter" Style="{StaticResource DetailValueStyle}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="영향 금액" Style="{StaticResource DetailKeyStyle}" />
                            <TextBlock x:Name="DetailImpact" Style="{StaticResource DetailValueStyle}" />

                            <TextBlock Text="메모" Style="{StaticResource DetailKeyStyle}" />
                            <TextBlock x:Name="DetailComment" Style="{StaticResource DetailValueStyle}" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 조치 -->
            <Border Grid.Column="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Lg}"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="조치" Style="{StaticResource CardTitleStyle}" />
                    <StackPanel>
                        <TextBlock Text="조치" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="ActionCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  Margin="0,0,0,12"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="선택하세요" />
                            <ComboBoxItem Content="수정요청" />
                            <ComboBoxItem Content="승인" />
                            <ComboBoxItem Content="반려" />
                            <ComboBoxItem Content="보류" />
                            <ComboBoxItem Content="검토완료" />
                        </ComboBox>

                        <TextBlock Text="사유코드" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox x:Name="ReasonCodeCombo"
                                  Style="{StaticResource FilterComboStyle}"
                                  Margin="0,0,0,12"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="선택하세요" />
                            <ComboBoxItem Content="근태 누락" />
                            <ComboBoxItem Content="미승인 연장근무" />
                            <ComboBoxItem Content="계좌정보 오류" />
                            <ComboBoxItem Content="공제정보 불일치" />
                            <ComboBoxItem Content="비정상 금액" />
                            <ComboBoxItem Content="대상자 오류" />
                            <ComboBoxItem Content="기타" />
                        </ComboBox>

                        <TextBlock Text="메모" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox x:Name="ActionCommentBox"
                                 Height="72"
                                 Margin="0,0,0,12"
                                 Padding="10,8"
                                 FontSize="{StaticResource Font.Size.Body}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderBrush="{StaticResource Brush.Border}" />

                        <Button x:Name="SubmitActionButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="조치 실행"
                                HorizontalAlignment="Stretch"
                                Click="SubmitActionButton_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 4. 감사 이력 -->
        <Border Grid.Row="3"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="감사 이력" Style="{StaticResource CardTitleStyle}" />
                <Border CornerRadius="{StaticResource Radius.Md}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource Brush.BorderSubtle}"
                        ClipToBounds="True">
                    <DataGrid x:Name="AuditGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource Brush.BorderSubtle}"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="{StaticResource Brush.Surface}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              AlternationCount="2"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                              RowStyle="{StaticResource GridRowStyle}"
                              CellStyle="{StaticResource GridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="시각" Binding="{Binding Time}" Width="140" />
                            <DataGridTextColumn Header="처리자" Binding="{Binding Actor}" Width="100" />
                            <DataGridTextColumn Header="조치" Binding="{Binding Action}" Width="100" />
                            <DataGridTextColumn Header="사유코드" Binding="{Binding ReasonCode}" Width="130" />
                            <DataGridTextColumn Header="변경 전" Binding="{Binding BeforeValue}" Width="*" />
                            <DataGridTextColumn Header="변경 후" Binding="{Binding AfterValue}" Width="*" />
                            <DataGridTextColumn Header="메모" Binding="{Binding Comment}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
