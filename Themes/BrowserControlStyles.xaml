<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Shared styles for the 사원 조회 controls so the code-hosted     -->
    <!-- variant (WpfOnFormDemo) matches EmployeeBrowserScreen exactly.  -->
    <!-- ============================================================= -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/com.example;component/Themes/Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="Browser.PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.OnAccent}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="{StaticResource Size.ControlHeight}" />
        <Setter Property="Padding" Value="{StaticResource Pad.Button}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource Radius.Md}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.DisabledBackground}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.DisabledText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Browser.FilterCombo" TargetType="ComboBox">
        <Setter Property="Height" Value="{StaticResource Size.ControlHeight}" />
        <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
    </Style>

    <Style x:Key="Browser.CardTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- Status badge: tone via Tag. -->
    <Style x:Key="Browser.Badge" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="{StaticResource Brush.HeaderBackground}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Style.Triggers>
            <Trigger Property="Tag" Value="info">
                <Setter Property="Background" Value="{StaticResource Brush.InfoBackground}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource Brush.Accent}" />
            </Trigger>
            <Trigger Property="Tag" Value="success">
                <Setter Property="Background" Value="{StaticResource Brush.SuccessBackground}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource Brush.Success}" />
            </Trigger>
            <Trigger Property="Tag" Value="warning">
                <Setter Property="Background" Value="{StaticResource Brush.WarningBackground}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource Brush.Warning}" />
            </Trigger>
            <Trigger Property="Tag" Value="danger">
                <Setter Property="Background" Value="{StaticResource Brush.ErrorBackground}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource Brush.ErrorBorder}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Browser.TreeItem" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="Margin" Value="0,1,0,1" />
    </Style>

    <Style x:Key="Browser.GridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Brush.HeaderBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="{StaticResource Size.GridHeaderHeight}" />
        <Setter Property="Padding" Value="{StaticResource Pad.Field}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style x:Key="Browser.GridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Style.Triggers>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Brush.HoverBackground}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Browser.GridCell" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource Pad.Item}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.SelectedBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.SelectedText}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 재직상태 cell: status badge -->
    <DataTemplate x:Key="Browser.StatusBadgeTemplate">
        <Border Style="{StaticResource Browser.Badge}" Tag="{Binding StatusTone}">
            <TextBlock Text="{Binding StatusLabel}" FontSize="{StaticResource Font.Size.Label}" FontWeight="Normal" />
        </Border>
    </DataTemplate>

</ResourceDictionary>
