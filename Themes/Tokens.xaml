<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================= -->
    <!-- Design tokens — modern, conservative enterprise desktop theme. -->
    <!-- Controls must consume these and never hardcode hex/px/weights.  -->
    <!-- ============================================================= -->

    <!-- 2. Spacing scale (4-based) -->
    <sys:Double x:Key="Space.Xs">4</sys:Double>
    <sys:Double x:Key="Space.Sm">8</sys:Double>
    <sys:Double x:Key="Space.Md">12</sys:Double>
    <sys:Double x:Key="Space.Lg">16</sys:Double>
    <sys:Double x:Key="Space.Xl">24</sys:Double>

    <!-- Derived layout tokens -->
    <sys:Double x:Key="Size.ControlHeight">40</sys:Double>
    <sys:Double x:Key="Size.FocusThickness">1.5</sys:Double>
    <Thickness x:Key="Pad.Field">12,0</Thickness>
    <Thickness x:Key="Pad.Item">12,8</Thickness>
    <Thickness x:Key="Gap.Label">0,0,0,8</Thickness>
    <Thickness x:Key="Gap.Helper">0,4,0,0</Thickness>

    <!-- 4. Corner radius -->
    <CornerRadius x:Key="Radius.Sm">4</CornerRadius>
    <CornerRadius x:Key="Radius.Md">4</CornerRadius>
    <CornerRadius x:Key="Radius.Lg">8</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">10</CornerRadius>

    <!-- 1. Color roles -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF7F8FA" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFEFF3FA" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD1D5DB" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFE5E7EB" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF111827" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF6B7280" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF0078D4" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF106EBE" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF005A9E" />
    <SolidColorBrush x:Key="Brush.DangerPressed" Color="#FF991B1B" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFCFE4F7" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF005A9E" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF0078D4" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#330078D4" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="Brush.ErrorBorder" Color="#FFDC2626" />

    <!-- Semantic tints (status/badge) — each role is a (background, text) pair so
         status surfaces stay legible without controls re-deriving their own hex. -->
    <SolidColorBrush x:Key="Brush.InfoBackground" Color="#FFEFF6FF" />
    <SolidColorBrush x:Key="Brush.InfoBorder" Color="#FFBFDBFE" />
    <SolidColorBrush x:Key="Brush.InfoText" Color="#FF1D4ED8" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF16A34A" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FFECFDF3" />
    <SolidColorBrush x:Key="Brush.SuccessText" Color="#FF15803D" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFD97706" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FFFFFBEB" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="#FFB45309" />
    <SolidColorBrush x:Key="Brush.ErrorBackground" Color="#FFFEF2F2" />
    <SolidColorBrush x:Key="Brush.ErrorText" Color="#FFB91C1C" />
    <SolidColorBrush x:Key="Brush.NeutralBackground" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="Brush.NeutralText" Color="#FF374151" />

    <!-- Overlay scrim for modal/loading backdrops (dark, semi-transparent). -->
    <SolidColorBrush x:Key="Brush.Scrim" Color="#66101828" />

    <!-- Matte data surface — a deliberately warm "stone" neutral set, kept
         separate from the cool-gray core theme so the matte grid keeps its
         distinct look. Roles mirror the core tokens (surface/border/text/...). -->
    <SolidColorBrush x:Key="Matte.Surface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Matte.RowAlt" Color="#FFFAFAF9" />
    <SolidColorBrush x:Key="Matte.RowHover" Color="#FFF5F5F4" />
    <SolidColorBrush x:Key="Matte.HeaderBackground" Color="#FFF2F2F0" />
    <SolidColorBrush x:Key="Matte.HeaderText" Color="#FF57534E" />
    <SolidColorBrush x:Key="Matte.Border" Color="#FFE4E4E1" />
    <SolidColorBrush x:Key="Matte.GridLine" Color="#FFEFEEEB" />
    <SolidColorBrush x:Key="Matte.Text" Color="#FF44403C" />
    <SolidColorBrush x:Key="Matte.SelectedBackground" Color="#FFE7E5E4" />
    <SolidColorBrush x:Key="Matte.SelectedText" Color="#FF1C1917" />

    <!-- Raw colors for ColorAnimation targets (animations need Color, not Brush) -->
    <Color x:Key="Color.Accent">#FF0078D4</Color>
    <Color x:Key="Color.TrackOff">#FFD1D5DB</Color>

    <!-- 3. Typography (Pretendard — embedded as an assembly resource so it renders
         even where the font is not installed system-wide. The pack URI points at the
         static font files under Assets\Fonts; Segoe UI / Malgun Gothic stay as
         fallbacks if the resource ever fails to load. -->
    <FontFamily x:Key="Font.Family">Segoe UI, Malgun Gothic</FontFamily>

    <!-- Type scale (device-independent sizes). Controls must reference these
         instead of hardcoding numeric FontSize values. -->
    <sys:Double x:Key="Font.Size.Micro">9</sys:Double>
    <sys:Double x:Key="Font.Size.Helper">12</sys:Double>
    <sys:Double x:Key="Font.Size.Label">12</sys:Double>
    <sys:Double x:Key="Font.Size.Body">14</sys:Double>
    <sys:Double x:Key="Font.Size.BodyLg">14</sys:Double>
    <sys:Double x:Key="Font.Size.Title">16</sys:Double>
    <sys:Double x:Key="Font.Size.Subtitle">16</sys:Double>
    <sys:Double x:Key="Font.Size.Heading">20</sys:Double>
    <sys:Double x:Key="Font.Size.PageTitle">22</sys:Double>
    <sys:Double x:Key="Font.Size.Display">28</sys:Double>

    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Helper" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Helper}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- 6. Depth — the only shadow in the system, for overlays/popups only. -->
    <!-- Fluent elevation: subtle resting shadow for cards (Card) and a deeper one
         for flyouts/popups (Popup). -->
    <DropShadowEffect x:Key="Shadow.Card"
                      Color="#FF000000"
                      Opacity="0.10"
                      BlurRadius="8"
                      ShadowDepth="1"
                      Direction="270" />
    <DropShadowEffect x:Key="Shadow.Popup"
                      Color="#FF101828"
                      Opacity="0.12"
                      BlurRadius="14"
                      ShadowDepth="3"
                      Direction="270" />

</ResourceDictionary>
